# ── Python ──
.venv/
__pycache__/
*.pyc
*.pyo

# ── 로컬 설정/도구 ──
.claude/
.env

# ── 모델·HF 캐시 (재다운로드 가능) ──
.cache/
*.safetensors
*.bin

# ── 매뉴얼 원문·색인 (사내 데이터 / 재생성 가능) ──
# crawl.py + build_index.py 로 사내망에서 재생성.
# 공개 저장소에 사내 금융시스템 매뉴얼 원문을 올리지 않기 위해 제외.
data/html/
data/xlsx/
data/index/
data/*.jsonl
data/*.json
data/AC*.json

# 수작업 변환 샘플(내부 자료)
0878_AC250400_지점계좌서비스약정등록내역.pdf
0878_AC250400_지점계좌서비스약정등록내역.xlsx

# ── 임시/OS ──
~$*.xlsx
*.tmp
.DS_Store
Thumbs.db

# ── 영상 제작 산출물 (video/ — mp4/캡처는 사내 데이터 포함, 커밋 금지) ──
video/out/*
!video/out/.gitkeep
video/captures/out/*.webm
video/captures/out/*.png
video/remotion/node_modules/
video/remotion/out/
video/remotion/public/demo/
video/remotion/public/fonts/

# 임원 보고 PDF 산출물
docs/report/out/*
!docs/report/out/.gitkeep
docs/report/template/PretendardVariable.woff2
