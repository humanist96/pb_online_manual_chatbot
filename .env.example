# 전부 로컬/오픈소스 — 외부 API 키 불필요.
# 사용 시: cp .env.example .env 후 필요 값만 수정. (스크립트는 os.environ 사용)

# HTTP 바인딩(기본은 현재 호스트만). 비루프백 바인딩은 인증 reverse proxy 뒤에서만
# PB_ALLOW_NON_LOOPBACK_BIND=I_ACKNOWLEDGE_REVERSE_PROXY_AUTH를 함께 설정한다.
HOST=127.0.0.1
PORT=8000
PB_MAX_CONCURRENT_QUERIES=2

# 임베딩 (로컬) — 기본 경량 한국어 모델(약 440MB)
EMBED_MODEL=jhgan/ko-sroberta-multitask   # 고정밀 대안: BAAI/bge-m3 (약 2.3GB)
EMBED_DEVICE=cpu                  # cpu | cuda

# 리랭커 (로컬) — 관련도 게이트("안녕" 등 무관 질의 차단)에 사용
RERANK_ENABLE=auto               # auto(모델 있으면 사용) | on | off(코사인만)
RERANK_MODEL=BAAI/bge-reranker-v2-m3   # 최초 1회 다운로드(약 600MB), 이후 오프라인
# 임계치 τ 는 src/calibrate_threshold.py --write 로 data/index/meta.json 에 보정 기록.

# LLM (로컬, Ollama)
LLM_BACKEND=none                  # none(안전한 기본) | ollama(명시적 opt-in)
LLM_MODEL=qwen2.5:7b-instruct     # 대안: exaone3.5:7.8b, qwen2.5:14b-instruct
OLLAMA_HOST=http://localhost:11434

# 검색 파라미터
RAG_TOPK=5
RAG_ALPHA=0.5                     # 0=BM25만, 1=dense만, 0.5=하이브리드
