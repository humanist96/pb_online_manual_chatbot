# 전부 로컬/오픈소스 — 외부 API 키 불필요.
# 사용 시: cp .env.example .env 후 필요 값만 수정. (스크립트는 os.environ 사용)

# 임베딩 (로컬) — 기본 경량 한국어 모델(약 440MB)
EMBED_MODEL=jhgan/ko-sroberta-multitask   # 고정밀 대안: BAAI/bge-m3 (약 2.3GB)
EMBED_DEVICE=cpu                  # cpu | cuda

# LLM (로컬, Ollama)
LLM_BACKEND=ollama                # ollama | none(추출형 폴백 강제)
LLM_MODEL=qwen2.5:7b-instruct     # 대안: exaone3.5:7.8b, qwen2.5:14b-instruct
OLLAMA_HOST=http://localhost:11434

# 검색 파라미터
RAG_TOPK=5
RAG_ALPHA=0.5                     # 0=BM25만, 1=dense만, 0.5=하이브리드
